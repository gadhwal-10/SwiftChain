generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis(version: "3.4.0")]
}

// ─── Enums ──────────────────────────────────────────────────────────────────────

enum RiderStatus {
  ONLINE
  OFFLINE
  BUSY
  ON_BREAK
}

enum VehicleType {
  BIKE
  SCOOTER
  CAR
  VAN
}

enum OrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OrderStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum OrderSource {
  MANUAL
  WHATSAPP
  API
}

enum DeliveryStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  RETURNED
}

// ─── Models ─────────────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  latitude  Float
  longitude Float
  address   String
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warehouses")
}

model Rider {
  id           String      @id @default(cuid())
  name         String
  phone        String      @unique
  email        String?
  avatar       String?
  status       RiderStatus @default(OFFLINE)
  latitude     Float?
  longitude    Float?
  maxCapacity  Int         @default(5)
  currentLoad  Int         @default(0)
  rating       Float       @default(5.0)
  totalDeliveries Int      @default(0)
  vehicleType  VehicleType @default(BIKE)
  vehiclePlate String?
  lastPingAt   DateTime?
  isActive     Boolean     @default(true)
  orders       Order[]
  deliveries   Delivery[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("riders")
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  customerName  String
  customerPhone String
  customerEmail String?
  product       String
  quantity      Int           @default(1)
  weight        Float?        @default(0.5)
  priority      OrderPriority @default(NORMAL)
  status        OrderStatus   @default(PENDING)
  latitude      Float
  longitude     Float
  address       String
  notes         String?
  source        OrderSource   @default(MANUAL)
  estimatedETA  DateTime?
  assignedAt    DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  failureReason String?
  retryCount    Int           @default(0)
  maxRetries    Int           @default(2)
  warehouseId   String
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])
  riderId       String?
  rider         Rider?        @relation(fields: [riderId], references: [id])
  delivery      Delivery?
  events        DeliveryEvent[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([priority])
  @@index([riderId])
  @@index([warehouseId])
  @@index([createdAt])
  @@map("orders")
}

model Delivery {
  id              String         @id @default(cuid())
  orderId         String         @unique
  order           Order          @relation(fields: [orderId], references: [id])
  riderId         String
  rider           Rider          @relation(fields: [riderId], references: [id])
  status          DeliveryStatus @default(IN_PROGRESS)
  routePolyline   String?
  distanceKm      Float?
  estimatedMins   Int?
  actualMins      Int?
  startedAt       DateTime       @default(now())
  completedAt     DateTime?
  waypoints       Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([riderId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  riderId   String?
  event     String
  details   Json?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
  @@map("delivery_events")
}
